{
  "name": "backtest-optimizer-v2",
  "workspace": "D:/codex/stock_analysis",
  "output_dir": "D:/codex/stock_analysis/data/optimizer",
  "base_config": {
    "name": "自动参数优化",
    "start_date": "2025-10-01",
    "end_date": "2026-03-19",
    "lookback_days": 120,
    "max_positions": 4,
    "max_single_position": 0.30,
    "initial_capital": 1000000,
    "fee_rate": 0.0001,
    "slippage_rate": 0.0001,
    "market_require_benchmark_above_ma20": true,
    "market_require_benchmark_ma20_up": false,
    "enabled_buy_rules": ["buy_strict", "buy_momentum"],
    "enabled_sell_rules": [
      "sell_trim",
      "sell_break_ma5",
      "sell_drawdown",
      "sell_time_stop",
      "sell_flip_loss",
      "sell_market_weak_drop"
    ]
  },
  "search": {
    "method": "random",
    "trials": 50,
    "seed": 42,
    "top_k": 5,
    "progress_every": 5,
    "checkpoint_every": 5,
    "stages": [
      {
        "name": "coarse",
        "method": "random",
        "trials": 12,
        "seed": 42,
        "top_k": 5,
        "relations": [
          {
            "left": "buy_strict_score_total",
            "operator": ">=",
            "right": "buy_momentum_score_total",
            "message": "严格买入总分阈值不应低于增强买入总分阈值"
          }
        ],
        "param_space": {
          "market_score_filter_min_avg": { "type": "int", "min": 33, "max": 50, "step": 1 },
          "market_score_filter_min_ma5": { "type": "int", "min": 33, "max": 50, "step": 1 },
          "enable_buy_momentum": { "type": "bool", "values": [true, false] },
          "enable_sell_time_stop": { "type": "bool", "values": [true, false] },
          "buy_strict_score_total": { "type": "int", "min": 50, "max": 78, "step": 2 },
          "buy_momentum_score_total": { "type": "int", "min": 50, "max": 72, "step": 2 },
          "buy_min_core_hits": { "type": "int", "min": 1, "max": 5, "step": 1 },
          "buy_amount_min": { "type": "float", "min": 200000000, "max": 400000000, "step": 50000000 },
          "max_single_position": { "type": "float", "min": 0.20, "max": 0.35, "step": 0.05 },
          "sell_market_score_threshold": { "type": "int", "min": 30, "max": 40, "step": 1 },
          "sell_market_drop_threshold": { "type": "float", "min": -4.0, "max": -2.0, "step": 0.5 }
        }
      },
      {
        "name": "refine",
        "method": "refine",
        "trials": 8,
        "seed": 84,
        "top_k": 5,
        "source_top_n": 3,
        "radius_steps": 1,
        "relations": [
          {
            "left": "buy_strict_score_total",
            "operator": ">=",
            "right": "buy_momentum_score_total",
            "message": "严格买入总分阈值不应低于增强买入总分阈值"
          }
        ],
        "param_space": {
          "market_score_filter_min_avg": { "type": "int", "min": 33, "max": 50, "step": 1 },
          "market_score_filter_min_ma5": { "type": "int", "min": 33, "max": 50, "step": 1 },
          "enable_buy_momentum": { "type": "bool", "values": [true, false] },
          "enable_sell_time_stop": { "type": "bool", "values": [true, false] },
          "buy_strict_score_total": { "type": "int", "min": 50, "max": 78, "step": 2 },
          "buy_momentum_score_total": { "type": "int", "min": 50, "max": 72, "step": 2 },
          "buy_min_core_hits": { "type": "int", "min": 1, "max": 5, "step": 1 },
          "buy_amount_min": { "type": "float", "min": 200000000, "max": 400000000, "step": 50000000 },
          "max_single_position": { "type": "float", "min": 0.20, "max": 0.35, "step": 0.05 },
          "sell_market_score_threshold": { "type": "int", "min": 30, "max": 40, "step": 1 },
          "sell_market_drop_threshold": { "type": "float", "min": -4.0, "max": -2.0, "step": 0.5 }
        }
      }
    ]
  },
  "constraints": {
    "min_trade_count": 5,
    "max_drawdown_lte": 0.25,
    "min_win_rate": 0.25
  },
  "objective": {
    "primary": "total_return",
    "mode": "max",
    "secondary": [
      { "field": "excess_return", "mode": "max" },
      { "field": "max_drawdown", "mode": "min" }
    ]
  },
  "report": {
    "save_csv": true,
    "save_json": true,
    "save_md": true
  }
}
